# انسخ هذا الملف إلى .env للتجربة محلياً (لا يُرفع لأي مكان عام).
# على Render: لا تستخدم ملف .env إطلاقاً — أضف هذه المتغيرات من
# Dashboard → اختر الخدمة → Environment → Add Environment Variable.

# ضع مفتاح API لمزوّد واحد فقط (أو أكثر، وسيُختار حسب الأولوية أدناه).
# الأولوية التلقائية عند توفر أكثر من مفتاح: Anthropic > Gemini > DeepSeek > OpenAI > مخصص

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=
# اختياري — الافتراضي claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Gemini (Google) ---
GEMINI_API_KEY=
# اختياري — الافتراضي gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# --- DeepSeek ---
DEEPSEEK_API_KEY=
# اختياري — الافتراضي deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat

# --- OpenAI ---
OPENAI_API_KEY=
# اختياري — الافتراضي gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# --- أي مزوّد آخر متوافق مع OpenAI (Groq, Mistral, OpenRouter, ...) ---
# AI_API_KEY=
# AI_BASE_URL=https://api.example.com/v1
# AI_MODEL=model-name

# اختياري: لإجبار استخدام مزوّد معيّن حتى لو كان أكثر من مفتاح مضبوطاً
# AI_PROVIDER=anthropic   # أو: gemini | deepseek | openai | custom
